---
// Hero Component - Research-Driven Design (2025)
//
// RESEARCH FINDINGS APPLIED:
// - Headlines under 10 words convert better (Source: B2B hero best practices 2025)
// - Split-screen layout balances visual storytelling with text (Source: Split-screen design trends)
// - Gradient text on key benefit word creates visual hierarchy (Source: 2025 typography trends)
// - Single primary CTA + optional secondary max (Source: Conversion optimization research)
// - Trust signals near headline boost credibility (Source: B2B landing page best practices)
// - Above-the-fold content with clear value proposition (Source: Hero section optimization)
//
// TEXT DECISIONS:
// - Headline: "Transform Your Website Into Results" (9 words, benefit-focused)
// - Focus on "transform" (action) and "results" (outcome) rather than features
// - Subhead emphasizes no-rebuild approach (key differentiator for target audience)
//
// COLOR DECISIONS:
// - Deep Blue (#1E3A8A) primary - Research shows trust and professionalism for B2B
// - Cyan (#06B6D4) accent - Modern, tech-forward, stands out
// - Gradient from cyan to blue on "Results" - 2025 trend for emphasis
//
// TYPOGRAPHY DECISIONS:
// - 5xl/7xl headline - Large, bold fonts trending in 2025
// - Inter font family - Clean, professional, excellent readability
// - Line height 1.1 (tight leading) - Creates impact with large text
---

<!-- Research: pt-32 adds extra top padding to account for fixed header (consistent with other pages) -->
<section class="relative min-h-screen flex items-center bg-gradient-to-br from-slate-50 to-slate-100 pt-32">
	<div class="container mx-auto px-6 py-20 lg:px-8">
		<div class="grid lg:grid-cols-2 gap-12 items-center">
			<!-- Content Column -->
			<div class="space-y-8">
				<!-- Overline / Tag -->
				<!-- Research: Pre-headline introduces product category (B2B best practices) -->
				<div class="inline-flex items-center gap-2 px-4 py-2 bg-brand-accent/10 rounded-full border border-brand-accent/20">
					<span class="w-2 h-2 bg-brand-accent rounded-full animate-pulse"></span>
					<span class="text-sm font-medium text-brand-primary">
						Marketing That Actually Works
					</span>
				</div>

				<!-- Main Headline -->
				<!-- Research: 9 words, benefit-driven, gradient on key outcome word -->
				<h1 class="text-5xl lg:text-7xl font-bold leading-tight text-brand-dark">
					Transform Your Website<br />
					Into <span class="bg-gradient-to-r from-brand-accent to-brand-primary bg-clip-text text-transparent">Results</span>
				</h1>

				<!-- Subheadline -->
				<!-- Research: Combines audience pain point (existing site) with solution (no rebuild) -->
				<p class="text-xl lg:text-2xl text-slate-600 leading-relaxed max-w-xl">
					We don't rebuild websites. We optimize what you have through expert backend SEO, compelling content, and high-converting landing pages.
				</p>

				<!-- CTA Buttons -->
				<!-- Research: Primary + secondary CTA max, contrasting colors, action-oriented text -->
				<div class="flex flex-col sm:flex-row gap-4">
					<a
						href="#services"
						class="inline-flex items-center justify-center px-8 py-4 bg-brand-primary text-white font-semibold rounded-lg hover:bg-brand-primary/90 transition-all duration-200 shadow-lg hover:shadow-xl hover:scale-105"
					>
						See Our Services
						<svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
						</svg>
					</a>
					<a
						href="/contact"
						class="inline-flex items-center justify-center px-8 py-4 bg-white text-brand-primary font-semibold rounded-lg border-2 border-brand-primary hover:bg-brand-primary hover:text-white transition-all duration-200"
					>
						Get Started
					</a>
				</div>

				<!-- Trust Indicators -->
				<!-- Research: Credibility elements near headline boost conversion -->
				<div class="flex items-center gap-6 pt-4 border-t border-slate-200">
					<div class="flex items-center gap-2">
						<svg class="w-5 h-5 text-brand-accent" fill="currentColor" viewBox="0 0 20 20">
							<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
						</svg>
						<span class="text-sm font-medium text-slate-700">Results-Driven</span>
					</div>
					<div class="flex items-center gap-2">
						<svg class="w-5 h-5 text-brand-accent" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
						</svg>
						<span class="text-sm font-medium text-slate-700">Proven Strategies</span>
					</div>
				</div>
			</div>

			<!-- Visual Column -->
			<!-- Research: Split-screen with visual on right balances text-heavy left side -->
			<div class="relative">
				<!-- Abstract Graphic -->
				<!-- Research: 2x2 grid showcasing 3 core services visually -->
				<div class="relative aspect-square rounded-2xl overflow-hidden bg-gradient-to-br from-brand-primary to-brand-accent p-1">
					<div class="w-full h-full bg-white rounded-xl flex items-center justify-center">
						<div class="grid grid-cols-2 gap-4 p-8 w-full h-full">
							<!-- SEO Icon -->
							<div class="bg-gradient-to-br from-brand-primary/10 to-brand-accent/10 rounded-xl p-6 flex flex-col items-center justify-center transform hover:scale-105 transition-transform">
								<svg class="w-16 h-16 text-brand-primary mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
								</svg>
								<span class="text-sm font-semibold text-brand-dark">SEO</span>
							</div>
							<!-- Content Icon -->
							<div class="bg-gradient-to-br from-brand-accent/10 to-brand-primary/10 rounded-xl p-6 flex flex-col items-center justify-center transform hover:scale-105 transition-transform">
								<svg class="w-16 h-16 text-brand-accent mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
								</svg>
								<span class="text-sm font-semibold text-brand-dark">Content</span>
							</div>
							<!-- Landing Pages Icon -->
							<div class="bg-gradient-to-br from-brand-primary/10 to-brand-accent/10 rounded-xl p-6 flex flex-col items-center justify-center transform hover:scale-105 transition-transform">
								<svg class="w-16 h-16 text-brand-accent mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
								</svg>
								<span class="text-sm font-semibold text-brand-dark">Landing Pages</span>
							</div>
							<!-- Results Icon -->
							<div class="bg-gradient-to-br from-brand-accent/10 to-brand-primary/10 rounded-xl p-6 flex flex-col items-center justify-center transform hover:scale-105 transition-transform">
								<svg class="w-16 h-16 text-brand-primary mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
								</svg>
								<span class="text-sm font-semibold text-brand-dark">Results</span>
							</div>
						</div>
					</div>
				</div>

				<!-- Decorative Blur Elements -->
				<!-- Research: Subtle depth without images (2025 gradient trend) -->
				<div class="absolute -z-10 -top-4 -right-4 w-72 h-72 bg-brand-accent/20 rounded-full blur-3xl"></div>
				<div class="absolute -z-10 -bottom-4 -left-4 w-72 h-72 bg-brand-primary/20 rounded-full blur-3xl"></div>
			</div>
		</div>
	</div>

	<!-- Scroll Indicator -->
	<!-- Research: Subtle animation guides users to content below -->
	<div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
		<svg class="w-6 h-6 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
		</svg>
	</div>
</section>
